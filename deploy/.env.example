SERVER_MODE=release

DB_HOST=postgres
DB_PORT=5432
DB_NAME=kvm-manager
DB_USER=postgres
DB_PASSWORD=123456ok!
DB_SSLMODE=disable

JWT_SECRET=change-me-in-production
