RUNTIME_SYNC_FULL_TIMEOUT_SECONDS=60
RUNTIME_SYNC_CONCURRENCY=3
METRIC_RETENTION_DAYS=30
METRIC_STREAM_MAXLEN=10000

LOG_RETENTION_DAYS=30